# Template para /etc/nginx/conf.d/mundografic_upstream.conf
#
# NO edites este archivo manualmente en el servidor.
# El script scripts/control-green.sh lo genera automáticamente al
# ejecutar las opciones 4 (promover green) o 5 (rollback a blue).
#
# Blue  (producción): 127.0.0.1:3002
# Green (staging):    127.0.0.1:4001

# Estado por defecto: apuntando a blue (producción)
upstream mundografic_backends {
  server 127.0.0.1:3002 max_fails=3 fail_timeout=5s;
}
